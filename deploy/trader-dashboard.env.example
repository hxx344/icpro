# Copy this file to /opt/project_Options/deploy/trader-dashboard.env
# and replace the placeholder values before starting trader-dashboard.service.

# Strategy config used by dashboard_app.py
TRADER_CONFIG_PATH=configs/trader/weekend_vol_btc.yaml

# Public bind is optional. Keep false unless you intentionally expose the UI.
DASHBOARD_PUBLIC=false

# Read-only account (recommended)
DASHBOARD_READONLY_USER=readonly
DASHBOARD_READONLY_PASS=change_me_readonly

# Trader account (required for live trading actions)
DASHBOARD_TRADER_USER=trader
DASHBOARD_TRADER_PASS=change_me_trader